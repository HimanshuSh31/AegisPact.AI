# AegisPact.AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./contract_auditor.db
# For PostgreSQL (Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:password123@localhost:5432/contract_auditor

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_ALWAYS_EAGER=True   # Set to False when Redis is running

# --- JWT Auth ---
JWT_SECRET=change_me_to_a_random_64_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Vector DB ---
QDRANT_URL=http://localhost:6333

# --- LLM / Embeddings ---
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3:8b

# --- File Storage ---
UPLOAD_DIR=./uploads
